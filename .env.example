PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your-postgres-password
DB_NAME=realworld
DB_SYNCHRONIZE=false
DB_LOGGING=true

# Optional: use this instead of DB_HOST/DB_PORT/DB_USER/DB_PASS/DB_NAME
# DATABASE_URL=postgresql://postgres:your-postgres-password@localhost:5432/realworld

JWT_SECRET=change-this-secret
ALLOWED_ORIGINS=*
